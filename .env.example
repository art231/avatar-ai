# Database Configuration
POSTGRES_DB=avatarai
POSTGRES_USER=avatarai
POSTGRES_PASSWORD=avatarai123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ISSUER=avatar-ai
JWT_AUDIENCE=avatar-ai-users
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# File Storage
FILE_STORAGE_PATH=/app/data
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.gif
ALLOWED_AUDIO_EXTENSIONS=.mp3,.wav,.ogg,.flac
ALLOWED_VIDEO_EXTENSIONS=.mp4,.mov,.avi,.mkv

# AI Services Configuration
AI_SERVICES_AUDIO_PREPROCESSOR_URL=http://audio-preprocessor:5004
AI_SERVICES_XTTS_SERVICE_URL=http://xtts-service:5003
AI_SERVICES_MEDIA_ANALYZER_URL=http://media-analyzer:5005
AI_SERVICES_LIPSYNC_SERVICE_URL=http://lipsync-service:5006

# XTTS Service Configuration
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_LANGUAGE=ru
XTTS_SPEAKER_WAV=/data/voice_samples/sample.wav

# MuseTalk Configuration
MUSETALK_MODEL_PATH=/app/models/musetalk
MUSETALK_DEVICE=cuda
MUSETALK_BATCH_SIZE=1

# Logging Configuration
LOG_LEVEL=Information
LOG_FILE_PATH=/app/logs/avatar-ai-.log
LOG_RETENTION_DAYS=30

# Hangfire Configuration
HANGFIRE_DASHBOARD_ENABLED=true
HANGFIRE_DASHBOARD_USERNAME=admin
HANGFIRE_DASHBOARD_PASSWORD=admin123

# Health Checks
HEALTH_CHECK_TIMEOUT_SECONDS=30
HEALTH_CHECK_ENABLED=true

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10